# LFCS Study Dashboard environment example
# Copy this file to .env for local development.
# Never commit real .env files.

# Application runtime
NODE_ENV=development
PORT=3000

# Initial admin bootstrap.
# Use a real email and a strong temporary password locally.
ADMIN_EMAIL=admin@example.com
ADMIN_INITIAL_PASSWORD=change-this-local-password

# Session signing secret.
# Generate a real value with:
#   openssl rand -base64 48
SESSION_SECRET=change-this-session-secret

# Local Grafana demo credentials for Docker Compose.
# These are for local portfolio use only, not public deployment.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-this-local-grafana-password
